# ═══════════════════════════════════════════════════════════════════════════════
# CogniLearn — Environment Variables Template
#
# Copy this file to the correct location and fill in your keys:
#
#   cp testbench/.env.example Backend/.env      ← backend keys
#
# For the frontend, create Frontend/.env with the VITE_ variables below.
# ═══════════════════════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────────────────────
# BACKEND  (save these in Backend/.env)
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] OpenAI API key — powers Ask Mode, Practice Mode, Test Mode,
#            and Voice Analysis. Get one at https://platform.openai.com/api-keys
OpenAI_KEY=sk-proj-REPLACE_WITH_YOUR_OPENAI_API_KEY

# [OPTIONAL] Supabase — only needed if you want persistent database storage.
#            Without these, the backend uses in-memory synthetic data.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...REPLACE_WITH_YOUR_SERVICE_ROLE_KEY


# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND  (save these in Frontend/.env)
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED for auth] Supabase project URL and anonymous key.
#   Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...REPLACE_WITH_YOUR_ANON_KEY

# [OPTIONAL] Backend API URL — defaults to http://localhost:8000 if omitted.
VITE_API_URL=http://localhost:8000
